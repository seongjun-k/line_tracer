<?xml version="1.0"?>
<launch>
  <node name="line_tracer_node"
        pkg="line_tracer"
        type="line_tracer_node.py"
        output="screen">
    <param name="camera_topic"         value="/camera/image" />

    <param name="linear_speed"         value="0.06" />

    <!-- PID 이득 -->
    <param name="kp"                   value="0.004" />
    <param name="ki"                   value="0.0" />
    <param name="kd"                   value="0.005" />
    <param name="dt"                   value="0.05" />
    <param name="flip_image"           value="false" />

    <!-- 흰 선 검출 -->
    <param name="white_threshold"      value="170" />
    <param name="min_line_area"        value="80" />
    <param name="max_blob_width_ratio" value="0.35" />

    <!--
      Near ROI: 0.65 유지 (하단 35% 구간 인식 → 커브 일찍 감지)
      FAR ROI: far_weight=0.0 으로 비활성 (노이즈 발산 방지)
    -->
    <param name="near_start_ratio"     value="0.65" />

    <param name="far_start_ratio"      value="0.50" />
    <param name="far_end_ratio"        value="0.62" />
    <!-- far 비활성: near만 사용 -->
    <param name="far_weight"           value="0.0" />
    <param name="near_weight"          value="1.0" />

    <!-- 커브 감속 트리거 -->
    <param name="curve_rate_threshold" value="150.0" />

    <param name="show_debug_window"    value="true" />
  </node>
</launch>

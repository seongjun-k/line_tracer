<?xml version="1.0"?>
<launch>
  <node name="line_tracer_node"
        pkg="line_tracer"
        type="line_tracer_node.py"
        output="screen">

    <param name="camera_topic"         value="/camera/image" />
    <param name="linear_speed"         value="0.05" />

    <!-- PID 이득 -->
    <param name="kp"                   value="0.004" />
    <param name="ki"                   value="0.0" />
    <param name="kd"                   value="0.005" />
    <param name="dt"                   value="0.05" />
    <param name="flip_image"           value="false" />

    <!-- 흰 선 검출 -->
    <param name="white_threshold"      value="170" />
    <param name="min_line_area"        value="80" />
    <param name="max_blob_width_ratio" value="0.35" />

    <!--
      [v10] 2단 ROI — 정면 카메라 기준 (선이 화면 하단에 맺힘)
      ┌─────────────────────┐  ← 0%
      │                     │
      │   (배경/하늘/벽)     │
      │                     │
      │  [주황] 예측 ROI    │  ← predict_start_ratio (0.65)
      │  PRED  65% ~ 75%   │
      │  [주황끝]           │  ← predict_end_ratio   (0.75)
      │                     │
      │  [빨강] 주행 ROI    │  ← drive_start_ratio   (0.77)
      │  DRIVE 77% ~ 95%   │
      │  [빨강끝]           │  ← drive_end_ratio     (0.95)
      │                     │
      └─────────────────────┘  ← 100%

      최종 조향 = DRIVE * 0.75 + PREDICT * 0.25
      선이 두 박스 모두 위에 있으면 predict_start_ratio를 더 낮추세요.
      선이 두 박스 아래(화면 밖)면 카메라를 아래로 기울이세요.
    -->
    <param name="predict_start_ratio"  value="0.65" />
    <param name="predict_end_ratio"    value="0.75" />
    <param name="drive_start_ratio"    value="0.77" />
    <param name="drive_end_ratio"      value="0.95" />
    <param name="drive_weight"         value="0.75" />
    <param name="predict_weight"       value="0.25" />

    <!-- 커브 감속 트리거 -->
    <param name="curve_rate_threshold" value="120.0" />

    <!-- 선 소실 유지 프레임 -->
    <param name="lost_max_frames"      value="8" />

    <param name="show_debug_window"    value="true" />
  </node>
</launch>
